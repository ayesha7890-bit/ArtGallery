@{
    ViewData["Title"] = "Contact us";
    Layout = "_UserLayout";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/Contactus.css" />

    <style>

        /* ======================================================= */
        /* === GLOBAL & BG STYLES for Contact Page === */
        /* ======================================================= */
        html, body {
            background-color: #000000;
            color: #ffffff;
            font-family: Arial, sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .contact-page-wrapper {
            position: relative;
            padding: 0;
            z-index: 1;
        }

        /* Art Image with Low Opacity */
        .art-background {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            /* Please replace this path with your local image path */
            background-image: url('https://picsum.photos/1920/1080?random=1');
            background-size: cover;
            background-position: center;
            opacity: 0.15;
            z-index: -1;
            transition: opacity 1s ease;
        }

        .contact-content-area {
            position: relative;
            z-index: 2;
            padding-bottom: 5rem;
        }

        /* ======================================================= */
        /* === CONTACT HEADER STYLES (Animated/Enhanced) === */
        /* ======================================================= */
        .contact-header {
            text-align: center;
            /* CONTENT KO UPER LAANE KE LIYE TOP PADDING KAM KI */
            padding: 2rem 0 3rem;
        }

        /* Logo/Brand (Removed from HTML, but CSS kept empty) */
        .page-brand-top {
            display: none; /* Isko chupa diya */
        }

        .contact-header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 4rem;
            font-weight: 700;
            background-image: linear-gradient(to right, #fff, #ffcc00);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 1rem;
            opacity: 0;
            transform: translateY(20px);
            animation: fadeInSlideUp 1s forwards 0.5s;
        }

      

        .contact-header small {
            display: block;
            text-transform: uppercase;
            letter-spacing: 3px;
            color: #ffaa00;
            font-weight: 600;
            margin-bottom: 0.5rem;
            animation: fadeIn 1s forwards;
        }

        .contact-header p {
            max-width: 700px;
            margin: 0 auto;
            color: #aaa;
            font-size: 1.1rem;
            line-height: 1.6;
        }

        /* ======================================================= */
        /* === FORM, INFO & MAP STYLES === */
        /* ======================================================= */
        .contact-form-card, .map-section {
            background-color: #0f0f0f;
            padding: 3rem;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        }

        /* Map Section Card (now within the right column) */
        .map-section-card {
            background-color: #0f0f0f;
            /* Adjusted for better fit */
            padding: 0;
            border-radius: 10px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
            margin-top: 1.5rem;
            height: 300px;
            position: relative;
            overflow: hidden;
        }

            .map-section-card h6 {
                color: #f7f7f7;
                font-weight: bold;
                margin-top: 0.5rem;
                margin-bottom: 0.5rem;
            }

            .map-section-card p {
                color: #aaa;
                margin-bottom: 0;
            }

        .form-control-custom {
            background-color: #1a1a1a;
            border: 1px solid #333;
            color: #e0e0e0;
            padding: 0.75rem 1rem;
            border-radius: 5px;
        }

        .form-label {
            color: #aaa !important;
            font-size: 0.9rem;
        }

        .form-control-custom:focus {
            background-color: #1a1a1a;
            border-color: #ffaa00;
            box-shadow: 0 0 0 0.1rem rgba(255, 170, 0, 0.5);
            color: #fff;
        }

        .contact-info-card {
            background-color: #0f0f0f;
            padding: 1.5rem;
            border-radius: 10px;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            transition: background-color 0.3s;
            height: 100%;
        }

            .contact-info-card:hover {
                background-color: #1a1a1a;
            }

        .contact-icon {
            font-size: 1.5rem;
            color: #ffaa00;
            margin-right: 1.5rem;
            width: 45px;
            height: 45px;
            display: flex;
            align-items: center;
            justify-content: center;
            background-color: rgba(255, 170, 0, 0.15);
            border-radius: 50%;
        }

        .contact-info-details h6 {
            font-size: 1.1rem;
            font-weight: bold;
            color: #f7f7f7;
            margin-bottom: 0.2rem;
        }

        .contact-info-details p {
            margin: 0;
            color: #aaa;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        .btn-submit {
            background: linear-gradient(to right, #ff9900, #ff4500);
            border: none;
            color: #000;
            padding: 0.75rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            border-radius: 5px;
            width: 100%;
            margin-top: 1rem;
            transition: opacity 0.3s;
        }

            .btn-submit:hover {
                opacity: 0.9;
                color: #000;
            }

        .map-section-card .map-embed {
            width: 100%;
            height: 100%;
            position: absolute;
            top: 0;
            left: 0;
            border-radius: 10px;
            overflow: hidden;
        }

            .map-section-card .map-embed iframe {
                width: 100%;
                height: 100%;
                border: 0;
                filter: grayscale(100%) invert(90%);
            }

        .map-content-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 10;
            background-color: rgba(15, 15, 15, 0.7);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            border-radius: 10px;
            text-align: center;
        }

        .map-pin-icon {
            font-size: 2.5rem;
            color: #ffaa00;
            margin-bottom: 0.5rem;
            position: relative;
            z-index: 2;
        }

    </style>
</head>
<body>

    <div class="contact-page-wrapper">
        <div class="art-background"></div>

        <div class="contact-header">
            <small>GET IN TOUCH</small>
            <h1>Contact Us</h1>
            <p>
                Have questions about our collection or interested in selling your artwork? We'd love to hear from you.
            </p>
        </div>

        <div class="contact-content-area container">
            <div class="row">

                <div class="col-lg-6 mb-5">
                    <div class="contact-form-card">
                        <h4 class="mb-4 text-white">Send a Message</h4>
                        <form>
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label">First Name</label>
                                    <input type="text" class="form-control form-control-custom" id="firstName" placeholder="John">
                                </div>
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label">Last Name</label>
                                    <input type="text" class="form-control form-control-custom" id="lastName" placeholder="Doe">
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="email" class="form-label">Email Address</label>
                                <input type="email" class="form-control form-control-custom" id="email" placeholder="john@example.com">
                            </div>
                            <div class="mb-3">
                                <label for="subject" class="form-label">Subject</label>
                                <input type="text" class="form-control form-control-custom" id="subject" placeholder="How can we help?">
                            </div>
                            <div class="mb-3">
                                <label for="message" class="form-label">Message</label>
                                <textarea class="form-control form-control-custom" id="message" rows="5" placeholder="Tell us about your inquiry."></textarea>
                            </div>
                            <button type="submit" class="btn btn-submit">Send Message</button>
                        </form>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="row">

                        <div class="col-md-6">
                            <div class="contact-info-card">
                                <span class="contact-icon"><i class="fas fa-map-marker-alt"></i></span>
                                <div class="contact-info-details">
                                    <h6>Visit Us</h6>
                                    <p>123 Art District</p>
                                    <p>New York, NY 10001</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="contact-info-card">
                                <span class="contact-icon"><i class="fas fa-phone-alt"></i></span>
                                <div class="contact-info-details">
                                    <h6>Call Us</h6>
                                    <p>+1 (555) 123-4567</p>
                                    <p>+1 (555) 987-6543</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="contact-info-card">
                                <span class="contact-icon"><i class="fas fa-envelope"></i></span>
                                <div class="contact-info-details">
                                    <h6>Email Us</h6>
                                    <p>hello@artisangallery.com</p>
                                    <p>support@artisangallery.com</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="contact-info-card">
                                <span class="contact-icon"><i class="fas fa-clock"></i></span>
                                <div class="contact-info-details">
                                    <h6>Working Hours</h6>
                                    <p>Mon - Fri: 9AM - 6PM</p>
                                    <p>Sat - Sun: 10AM - 4PM</p>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="map-section-card">
                                <div class="map-embed">
                                    <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3022.203774844052!2d-73.98785728459468!3d40.74844007932822!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89c2598587635293%3A0x6b77c5c065f5e8f!2sEmpire%20State%20Building!5e0!3m2!1sen!2sus!4v1620000000000!5m2!1sen!2sus"
                                            allowfullscreen=""
                                            loading="lazy">
                                    </iframe>
                                </div>
                                <div class="map-content-overlay">
                                    <span class="map-pin-icon"><i class="fas fa-map-marker-alt"></i></span>
                                    <h6>Visit Our Gallery</h6>
                                    <p>123 Art District, New York</p>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>