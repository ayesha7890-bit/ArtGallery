@model ArtGallery.Models.User

@{
    Layout = "_AccountLayout";
}
@* 


<div class="text-center mb-4">
    <div class="mb-3">
        <span class="step-pill">Create Account</span>
    </div>
    <h2 class="fw-bold mb-1">Join <span class="gold-text">ArtGallerY</span></h2>
    <p class="text-muted small">Fill in the details to start your creative journey</p>
</div> *@

<style>
    /* Dropdown Fix */
    .input-dark {
        background-color: #2a2a2a !important; /* Dark background */
        color: white !important; /* White text */
        border: 1px solid #444 !important;
    }

        /* Dropdown ke andar ke options ko style karna */
        .input-dark option {
            background-color: #1a1a1a; /* Option list background */
            color: white;
        }

    /* Subtitle line fix */
    .text-white-50 {
        color: rgba(255, 255, 255, 0.6) !important;
        display: block; /* Ensure it's not hidden */
    }

    /* Labels fix */
    .form-label {
        color: rgba(255, 255, 255, 0.8) !important;
    }

    .extra-small {
        font-size: 0.75rem;
    }

    .input-group-text {
        border-radius: 8px 0 0 8px;
        border-right: none;
        background-color: #212529 !important;
        border: 1px solid #444;
    }

    /* Input field border fix */
    .form-control.input-dark, .form-select.input-dark {
        border-radius: 8px !important;
    }
</style>
<div class="text-center mb-4">
    <div class="mb-3">
        <span class="step-pill">Create Account</span>
    </div>
    <h2 class="fw-bold mb-1 text-white">Join <span class="gold-text">ArtGallerY</span></h2>
    <p class="text-white-50 small">Fill in the details to start your creative journey</p>
</div>

<form asp-action="Register" method="post">
    @* General errors dikhane ke liye *@
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

    <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase opacity-50">Full Name</label>
        <div class="input-group">
            @* <span class="input-group-text bg-dark border-0 text-muted"><i class="bi bi-person"></i></span> *@
            <input asp-for="FullName" type="text" class="form-control input-dark" placeholder="John Doe" />
        </div>
        <span asp-validation-for="FullName" class="text-danger extra-small"></span>
    </div>

    <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase opacity-50">Email Address</label>
        <div class="input-group">
            @* <span class="input-group-text bg-dark border-0 text-muted"><i class="bi bi-envelope"></i></span> *@
            <input asp-for="Email" type="email" class="form-control input-dark" placeholder="name@example.com" />
        </div>
        <span asp-validation-for="Email" class="text-danger extra-small"></span>
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label small fw-bold text-uppercase opacity-50">Password</label>
            <input asp-for="Password" type="password" class="form-control input-dark" placeholder="••••••••" id="passInput" />
            <span asp-validation-for="Password" class="text-danger extra-small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label class="form-label small fw-bold text-uppercase opacity-50">Register As</label>
            <select asp-for="Role" class="form-select input-dark">
                <option value="User">Art Lover (Buyer)</option>
                <option value="Artist">Creative (Artist)</option>
            </select>
            <span asp-validation-for="Role" class="text-danger extra-small"></span>
        </div>
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-action w-100 py-2">
            Register Account <i class="bi bi-arrow-right ms-2"></i>
        </button>
    </div>

    <div class="text-center mt-4">
        <p class="text-white-50 small">
            Already have an account?
            <a asp-action="Login" class="gold-text text-decoration-none fw-bold ms-1">LOGIN HERE</a>
        </p>
    </div>
</form>

<script>
    await Html.RenderPartialAsync("_ValidationScriptsPartial");

</script>
  

    <style>
        .extra-small { font-size: 0.75rem; }
        .input-group-text { border-radius: 8px 0 0 8px; border-right: none; }
        .input-dark { border-radius: 0 8px 8px 0 !important; }
    </style>
