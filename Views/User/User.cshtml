@model IEnumerable<ArtGallery.Models.Exhibition>
@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

@{
    ViewData["Title"] = "Artistry - Where Art Meets Soul";
    Layout = null;

    var categories = ViewBag.Categories as IEnumerable<ArtGallery.Models.Category>;
    var artworks = ViewBag.ArtWorks as IEnumerable<ArtGallery.Models.Artist>;
    var selectedCat = ViewBag.SelectedCategory as string;
}
@{
    var biddingArt = ViewBag.BiddingArtWorks as IEnumerable<ArtGallery.Models.Artist>;
    var galleryArt = ViewBag.ArtWorks as List<ArtGallery.Models.Artist>;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/User.css">

    <style>
        .btn-art-solid {
            background: linear-gradient(45deg, #FFD700, #FF8C00); /* Yellow to Orange */
            color: #000 !important;
            font-weight: 700;
            border: none;
            padding: 8px 22px;
            border-radius: 50px;
            transition: 0.3s all ease;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(255, 140, 0, 0.3);
        }

       
        /* Auction Section Background */
        .auction-container {
            background-color: #0a0a0a;
            padding: 60px 0;
        }

        /* Horizontal Card Styling */
        .auction-horizontal-card {
            background: #1a1a1a;
            border-radius: 20px;
            overflow: hidden;
            display: flex; /* Horizontal Layout */
            border: 1px solid #333;
            transition: transform 0.3s ease;
            margin-bottom: 20px;
            min-height: 280px;
        }

            .auction-horizontal-card:hover {
                transform: translateY(-5px);
                border-color: #ff9a00;
            }

        .auction-img-wrapper {
            width: 40%; /* Image area */
            position: relative;
        }

            .auction-img-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .auction-content {
            width: 60%; /* Content area */
            padding: 30px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .live-indicator {
            position: absolute;
            top: 15px;
            left: 15px;
            background: rgba(255, 0, 0, 0.8);
            color: white;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: bold;
            display: flex;
            align-items: center;
        }

        .live-dot {
            height: 8px;
            width: 8px;
            background-color: #fff;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
            animation: blink 1s infinite;
        }
        /* Wishlist Icon Styling */
        .wishlist-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 10;
            background: rgba(255, 255, 255, 0.2);
            backdrop-filter: blur(5px);
            border: none;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            color: white;
            transition: all 0.3s ease;
        }

            .wishlist-btn:hover {
                background: white;
                color: #ff4d4d;
                transform: scale(1.1);
            }

            .wishlist-btn.active i {
                color: #ff4d4d;
                font-weight: 900; /* Solid heart */
            }
       

        .bid-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 20px;
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 12px;
        }

        .current-bid-label {
            color: #888;
            font-size: 0.8rem;
        }

        .current-bid-value {
            color: #ff9a00;
            font-size: 1.5rem;
            font-weight: bold;
        }
    

            .btn-art-solid:hover {
                background: linear-gradient(45deg, #FF8C00, #FFD700);
                transform: translateY(-2px);
                box-shadow: 0 6px 15px rgba(255, 140, 0, 0.4);
            }

        /* 2. Sign In ke liye Outline Button */
        .btn-art-outline {
            border: 2px solid #FFD700;
            color: #FFD700 !important;
            background: transparent;
            font-weight: 600;
            padding: 7px 20px;
            border-radius: 50px;
            transition: 0.3s all;
            text-decoration: none;
            margin-right: 10px;
        }

            .btn-art-outline:hover {
                background: #FFD700;
                color: #000 !important;
            }
        /* Logout Button Gradient Styling */
        .btn-gradient-logout {
            background: linear-gradient(45deg, #ff9a00, #ffc107); /* Orange to Yellow gradient */
            border: none;
            color: #000 !important; /* Text color black for better contrast */
            border-radius: 50px; /* Rounded pill shape */
            transition: all 0.4s ease;
            font-size: 0.9rem;
            letter-spacing: 0.5px;
        }

            .btn-gradient-logout:hover {
                background: linear-gradient(45deg, #ffc107, #ff9a00); /* Gradient reverse on hover */
                box-shadow: 0 4px 15px rgba(255, 193, 7, 0.4); /* Glow effect */
                transform: translateY(-2px); /* Slight lift */
                color: #000 !important;
            }

                /* Icon rotation effect on hover */
                .btn-gradient-logout:hover i {
                    transform: rotate(90deg);
                    transition: transform 0.3s ease;
                }
        /* Extra CSS for smooth filtering */
        .exhibition-item {
            transition: all 0.4s ease-in-out;
        }

        .tab-btn.active {
            background-color: #ffc107 !important;
            color: #000 !important;
        }

        .hidden-exh {
            display: none;
        }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand navbar-brand-custom" href="#">ArtGallerY</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link text-white" href="#">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#">About Us</a></li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="User" asp-action="MyOrders">My Orders</a>
                    </li>

                    @* <a href="#collection" class="btn btn-explore">Explore Gallery <i class="fas fa-arrow-right ms-2"></i></a>  *@

                    <li class="nav-item"><a class="nav-link text-white" href="#Exhibitions">Exhibition</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#">Auctions</a></li>
                </ul>

              
                    @if (HttpContextAccessor.HttpContext.Session.GetString("UserName") != null)
                    {
                        <span class="text-white me-3">Hi, <b>@HttpContextAccessor.HttpContext.Session.GetString("UserName")</b></span>

                        <a asp-action="Logout" asp-controller="User" class="btn-art-solid">
                            <i class="fas fa-sign-out-alt"></i> Logout
                        </a>
                    }
                    else
                    {
                        <a asp-action="Login" asp-controller="User" class="btn-art-outline">
                            Sign In
                        </a>

                        <a asp-action="Register" asp-controller="User" class="btn-art-solid">
                            Sign Up
                        </a>
                    }
                
            </div>
        </div>
    </nav>

    <div class="hero-section">
        <div class="hero-background"></div>
        <div class="hero-content" data-aos="zoom-out" data-aos-duration="2000">
            <h1 class="hero-title">Where Art <br><span class="highlight">Meets Soul</span></h1>
            <p class="mt-4 text-secondary fs-5 mx-auto" style="max-width: 600px;">Experience a digital sanctuary of creativity. Discover masterpieces that resonate with your inner self.</p>
            <div class="mt-5">
                 <a href="#collection" class="btn btn-explore">Explore Gallery <i class="fas fa-arrow-right ms-2"></i></a> 
            </div>
        </div>
    </div>



   
    <div class="container py-5" id="Exhibitions">
        <div class="d-flex justify-content-between align-items-end mb-4" data-aos="fade-right">
            <div>
                <span class="text-uppercase gold-text fw-bold small">Current & Upcoming</span>
                <h2 class="fw-bold mt-1">Featured Exhibitions</h2>
            </div>
        </div>

       
        <div class="row g-4">
            @foreach (var exh in Model)

            {
                var isCurrent = (DateTime.Today >= exh.StartDate.Date && DateTime.Today <= exh.EndDate.Date);
                var isUpcoming = (DateTime.Today < exh.StartDate.Date);

                <div class="col-lg-4 col-md-6 mb-4">
                    <div class="exh-card-premium h-100">
                        <div class="exh-img-wrapper">
                            <img src="@exh.BannerImage" class="preview-img" alt="@exh.Title">

                            @if (isCurrent)
                            {
                                <span class="badge bg-success-gradient position-absolute top-0 start-0 m-3">Now Open</span>
                            }
                            else if (isUpcoming)
                            {
                                <span class="badge bg-warning-gradient position-absolute top-0 start-0 m-3 text-dark">Upcoming</span>
                            }

                            <div class="artworks-count">
                                <small class="fw-bold">@exh.ExhibitionId artworks</small>
                            </div>
                        </div>

                        <div class="card-body d-flex flex-column p-4">
                            <h4 class="fw-bold text-white mb-2">@exh.Title</h4>
                            <p class="description-text">@exh.Description</p>

                            <div class="exh-meta mt-auto pt-3">
                                <div class="d-flex align-items-center mb-1">
                                    <i class="far fa-calendar-alt me-2 text-warning"></i>
                                    <span class="text-white-50 small">@exh.StartDate.ToString("MMM dd") — @exh.EndDate.ToString("MMM dd, yyyy")</span>
                                </div>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fas fa-map-marker-alt me-2 text-warning"></i>
                                    <span class="text-white-50 small">@exh.Venue</span>
                                </div>
                                <a href="#" class="view-exh-link text-decoration-none" data-bs-toggle="modal" data-bs-target="#exhibitionModal-@exh.ExhibitionId">
                                    VIEW EXHIBITION <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @if (TempData["OrderSuccess"] != null)
    {
        <script>
            Swal.fire({
                title: 'Request Sent!',
                text: '@TempData["OrderSuccess"]',
                icon: 'success',
                confirmButtonColor: '#3085d6',
                confirmButtonText: 'Theek Hai'
            });
        </script>
    }
    <section class="art-gallery-section" id="collection">
        <div class="container">
            <div class="gallery-header text-center mb-5" data-aos="fade-up">
                <h1>Featured <span>Masterpieces</span></h1>
                <p>Explore our handpicked selection arranged by category</p>
            </div>

            <div class="filter-tabs text-center mb-5" data-aos="fade-up">
                <a href="@Url.Action("User", "User", new { categoryName = "All" })#collection"
                   class="tab @(string.IsNullOrEmpty(selectedCat) || selectedCat == "All" ? "active" : "")">All</a>

                @if (categories != null)
                {
                    foreach (var cat in categories)
                    {
                        <a href="@Url.Action("User", "User", new { categoryName = cat.Name })#collection"
                           class="tab @(selectedCat == cat.Name ? "active" : "")">
                            @cat.Name
                        </a>
                    }
                }
            </div>
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            

            <div class="art-grid">
                @if (artworks != null && artworks.Any())
                {
                    int i = 0;
                    foreach (var art in artworks)
                    {

                        @if (art.AuctionEndTime < DateTime.Now)
                        {
                            var winner = art.Biding.OrderByDescending(b => b.BidAmount).FirstOrDefault();
                            if (winner != null)
                            {
                                <div class="alert alert-success p-1 small mt-2">
                                    🏆 Winner: @winner.User.FullName
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-secondary p-1 small mt-2">No Bids Placed</div>
                            }
                        }
                        var highestBid = art.Biding != null && art.Biding.Any()
                        ? art.Biding.Max(b => b.BidAmount)
                        : art.StartingBid;

                        string gridClass = (i % 4 == 0) ? "large" : (i % 4 == 3) ? "tall" : "small";

                        <div class="art-card @gridClass" data-aos="fade-up">
                            <button class="wishlist-btn" onclick="addToWishlist(@art.ArtworkId, this)" title="Add to My Gallery">
                                <i class="far fa-heart"></i>
                            </button>

                            <img src="@(string.IsNullOrEmpty(art.ImageUrl) ? "/images/placeholder.jpg" : art.ImageUrl)" alt="@art.Title">

                            <span class="badge @(art.Type == "Auction" ? "bg-purple" : "bg-warning")">
                                @art.Type
                            </span>

                            <div class="art-card-overlay">
                                <div class="overlay-content text-center w-100 px-3">
                                    <h4 class="text-white mb-1">@art.Title</h4>
                                    <p class="small text-white-50 mb-2">Category: @art.Category</p>

                                    @if (art.Type == "Auction")
                                    {
                                        <div class="bid-box mb-3">
                                            <span class="d-block small text-light">Current Highest Bid</span>
                                            <span class="text-warning fw-bold fs-5">PKR @highestBid?.ToString("N0")</span>

                                            @* Total Bids Count *@
                                            @if (art.Biding != null && art.Biding.Any())
                                            {
                                                <br />
                                                <small class="text-white-50" style="font-size: 0.75rem;">
                                                    <i class="fas fa-gavel"></i> @art.Biding.Count Bids Placed
                                                </small>
                                            }
                                        </div>

                                        <button type="button"
                                                class="btn btn-sm btn-outline-warning w-75 fw-bold"
                                                onclick="openBidModal('@art.ArtworkId', '@art.Title', '@highestBid')">
                                            <i class="fas fa-plus me-1"></i> Place Bid
                                        </button>
                                    }
                                    else
                                    {

                                        @* <span class="text-warning fw-bold fs-5">PKR @(art.StartingBid.HasValue? art.StartingBid.Value.ToString("N0") : "0")</span> *@

                                        <p class="text-warning mb-3 fs-5 fw-bold">PKR @art.Price.ToString("N0")</p>
                                        @* --- Buy Now Button Logic --- *@
                                        <div class="buy-action-wrapper">
                                            <input type="hidden" class="artwork-id-field" value="@art.ArtworkId" />

                                            @if (HttpContextAccessor.HttpContext.Session.GetString("UserId") != null)
                                            {
                                                <button type="button" class="btn btn-sm btn-warning w-75 mb-2 fw-bold onclick-buy">
                                                    <i class="fas fa-shopping-cart me-1"></i> Buy Now
                                                </button>
                                            }
                                            else
                                            {
                                                <a asp-action="Login" asp-controller="User" class="btn btn-sm btn-warning w-75 mb-2 fw-bold">
                                                    Login to Buy
                                                </a>
                                            }
                                        </div>
                                        
                                    }

                                    <a href="#" class="text-white-50 small d-block mt-2">View Details</a>
                                </div>
                            </div>
                        </div>
                        i++;
                    }
                }
            </div>
         
    </section>
    <section class="auction-container">
        <div class="container text-center mb-5" data-aos="fade-up">
            <span class="badge rounded-pill px-3 py-2 mb-3" style="background: rgba(255,154,0,0.1); color: #ff9a00; border: 1px solid #ff9a00;">
                <i class="fas fa-gavel me-2"></i> Live Auctions
            </span>
            <h1 class="text-white fw-bold display-5">Bid on <span style="color: #ff9a00;">Exclusive</span> Art</h1>
            <p class="text-secondary mx-auto" style="max-width: 600px;">Participate in live auctions and own rare masterpieces from acclaimed artists worldwide.</p>
        </div>

        <div class="container">
            <div class="row">
                @if (biddingArt != null && biddingArt.Any())
                {
                    foreach (var art in biddingArt)
                    {
                        var highestBid = art.Biding != null && art.Biding.Any()
                        ? art.Biding.Max(b => b.BidAmount)
                        : art.StartingBid;

                        <div class="col-lg-6" data-aos="zoom-in">
                            <div class="auction-horizontal-card">
                                <div class="auction-img-wrapper">
                                    <div class="live-indicator">
                                        <span class="live-dot"></span> LIVE
                                    </div>
                                    <img src="@art.ImageUrl" alt="@art.Title">
                                </div>

                                <div class="auction-content">
                                    <h3 class="text-white mb-1">@art.Title</h3>
                                    <p class="text-secondary small mb-3">by @(art.Category ?? "Exclusive Artist")</p>

                                   
                                    <small class="text-secondary">
                                        <i class="far fa-clock me-2"></i> Ends in:
                                        <span class="text-white auction-timer"
                                            data-endtime="@(art.AuctionEndTime?.ToString("yyyy-MM-ddTHH:mm:ss") ?? "")">
                                            Calculating...
                                        </span>
                                    </small>

                                    <div class="bid-info-row">
                                        <div>
                                            <span class="current-bid-label d-block">Current Bid</span>
                                            <span class="current-bid-value">$@highestBid?.ToString("N0")</span>
                                        </div>
                                        <div class="text-end">
                                            <span class="text-secondary small d-block">Total Bids</span>
                                            <span class="text-white fw-bold">@(art.Biding?.Count ?? 0) bids</span>
                                        </div>
                                    </div>

                                    <button onclick="openBidModal('@art.ArtworkId', '@art.Title', '@highestBid')"
                                            class="btn btn-art-solid mt-4 w-100 py-3">
                                        Place Bid <i class="fas fa-arrow-right ms-2"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>

        
        </div>
    </section>

    <section class="final-about-section">
        <div class="art-wrapper">
            <div class="art-content-left">
                <span class="gold-label">ABOUT US</span>
                <h2 class="art-title">Where Art Meets <span class="gold-text">Passion</span></h2>
                <div class="art-description">
                    <p>Artisan Gallery is more than an online marketplace — it's a global community connecting artists and art lovers. We believe that exceptional art should be accessible to everyone.</p>
                    <p>Founded in 2018, we've helped thousands of collectors discover their perfect pieces while supporting independent artists worldwide.</p>
                </div>
                <div class="art-stats-group">
                    <div class="stat-box"><h3>5000+</h3><p>Artworks Sold</p></div>
                    <div class="stat-box"><h3>200+</h3><p>Partner Artists</p></div>
                    <div class="stat-box"><h3>50+</h3><p>Countries</p></div>
                </div>
            </div>

            <div class="art-features-right">
                <div class="feat-card">
                    <i class="fas fa-shield-alt"></i>
                    <h4>Authentic Artwork</h4>
                    <p>Every piece is verified and comes with a certificate of authenticity.</p>
                </div>
                <div class="feat-card">
                    <i class="fas fa-truck"></i>
                    <h4>Secure Delivery</h4>
                    <p>Professional packaging and insured worldwide shipping.</p>
                </div>
                <div class="feat-card">
                    <i class="fas fa-certificate"></i>
                    <h4>Expert Curation</h4>
                    <p>Our team of art experts carefully selects each piece for quality.</p>
                </div>
                <div class="feat-card">
                    <i class="fas fa-heart"></i>
                    <h4>Artist Support</h4>
                    <p>We work directly with artists, ensuring fair compensation.</p>
                </div>
            </div>
        </div>
    </section>

    <footer class="footer-custom">
        <div class="container-fluid px-5">
            

            <div class="modal fade" id="bidModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content bg-dark text-white border-warning">
                        <div class="modal-header border-secondary">
                            <h5 class="modal-title">Place Your Bid</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                        </div>
                        <form asp-action="PlaceBid" asp-controller="User" method="post">
                            <div class="modal-body">
                                <h6 id="artTitle" class="text-warning mb-3"></h6>
                                <input type="hidden" name="ArtworkId" id="artId" />

                                <div class="mb-3">
                                    <label class="form-label">Apni Bid likhein (PKR)</label>
                                    <input type="number" name="BidAmount" id="minBidInput" class="form-control bg-secondary text-white border-0" required />
                                  
                                    <small class="text-white-50">Current Required: > PKR <span id="startPrice"></span></small>
                                </div>
                            </div>
                            <div class="modal-footer border-secondary">
                                <button type="submit" class="btn btn-warning w-100 fw-bold">Confirm Bid</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">

            <div class="footer-bottom pb-3">
                <p class="mb-0">&copy; 2024 Artisan Gallery. All rights reserved.</p>
                <div class="bottom-links">
                    <a href="#">Privacy Policy</a>
                    <a href="#">Terms of Service</a>
                    <a href="#">Cookie Policy</a>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>


    <script>
        AOS.init({ duration: 1200, once: true });

        $(window).scroll(function() {
            if ($(this).scrollTop() > 50) {
                $('.navbar-custom').addClass('navbar-scrolled');
            } else {
                $('.navbar-custom').removeClass('navbar-scrolled');
            }
        });
                      $(document).ready(function () {
            // Purani saari onclick-buy wali script hata kar ye lagayein
            $('.onclick-buy').off('click').on('click', function (e) {
                e.preventDefault();

                var button = $(this);
                // Wrapper div se ID uthayein
                var container = button.closest('.buy-action-wrapper');
                var artId = container.find('.artwork-id-field').val();

                $.ajax({
                    url: '/User/BuyNow',
                    type: 'POST',
                    data: { artworkId: artId },
                    success: function (response) {
                        Swal.fire({
                            title: 'Request Sent!',
                            text: 'send  your request  admin ',
                            icon: 'success',
                            confirmButtonColor: '#ffc107',
                            confirmButtonText: 'its Done'
                        });
                    },
                    error: function () {
                        Swal.fire('Error', 'error', 'error');
                    }
                });
            });
        });
         function openBidModal(id, title, price) {
            document.getElementById('artId').value = id;
            document.getElementById('artTitle').innerText = title;
            document.getElementById('startPrice').innerText = price;
            document.getElementById('minBidInput').min = parseFloat(price) + 1;

            var myModal = new bootstrap.Modal(document.getElementById('bidModal'));
            myModal.show();
        }
          
        function updateAllTimers() {
            // Tamam timer elements ko select karein
            const timerElements = document.querySelectorAll('.auction-timer');

            timerElements.forEach(timer => {
                const endTimeStr = timer.getAttribute('data-endtime');
                const endTime = new Date(endTimeStr).getTime();
                const now = new Date().getTime();
                const distance = endTime - now;

                // Agar time khatam ho gaya ho
                if (distance < 0) {
                    timer.innerHTML = "AUCTION ENDED";
                    timer.style.color = "#ff4d4d"; // Red color for ended

                    // Optional: Bid button ko disable karna
                    const card = timer.closest('.auction-horizontal-card');
                    if(card) {
                        const bidBtn = card.querySelector('button');
                        if(bidBtn) bidBtn.disabled = true;
                    }
                    return;
                }

                // Time calculations (Days, Hours, Minutes, Seconds)
                const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((distance % (1000 * 60)) / 1000);

                // Display format: 02d : 10h : 05m : 30s
                let timeString = "";
                if (days > 0) timeString += days + "d : ";
                timeString += hours.toString().padStart(2, '0') + "h : " +
                              minutes.toString().padStart(2, '0') + "m : " +
                              seconds.toString().padStart(2, '0') + "s";

                timer.innerHTML = timeString;
            });
        }

       
        updateAllTimers();

