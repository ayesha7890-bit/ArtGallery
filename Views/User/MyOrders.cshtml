@model IEnumerable<ArtGallery.Models.Order>
@{
    Layout = "_UserLayout";
}

<style>
    /* Main Container */
    .purchase-history-section {
        background-color: #121212; /* Dark background */
        padding: 40px;
        border-radius: 12px;
        color: #e0e0e0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Table Styling */
    .custom-art-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 12px; /* Rows ke beech ka gap */
        margin-top: 20px;
    }

        .custom-art-table thead th {
            color: #777;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            padding: 10px 20px;
            border: none;
        }

        /* Table Row Background & Transition */
        .custom-art-table tbody tr {
            background-color: #1e1e1e; /* Row color */
            transition: all 0.3s ease-in-out;
        }

            /* IMAGE HOVER EFFECT - Jaisa aapne manga tha */
            .custom-art-table tbody tr:hover {
                background-color: #2c2419; /* Brownish highlight */
                transform: translateY(-2px);
                box-shadow: 0 4px 15px rgba(0,0,0,0.4);
            }

        .custom-art-table td {
            padding: 15px 20px;
            vertical-align: middle;
            border: none;
        }

    /* Artwork Image Styling */
    .art-thumb {
        width: 55px;
        height: 55px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #333;
    }

    /* Price Highlight */
    .price-tag {
        color: #ff9f43;
        font-weight: 600;
        font-size: 1.1rem;
    }

    /* Status Badge Custom */
    .badge-approved {
        color: #2ecc71;
        background: rgba(46, 204, 113, 0.1);
        border: 1px solid #2ecc71;
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: bold;
    }

    .badge-pending {
        color: #f1c40f;
        background: rgba(241, 196, 15, 0.1);
        border: 1px solid #f1c40f;
        padding: 5px 12px;
        border-radius: 4px;
        font-size: 0.7rem;
    }

    /* Custom Action Button */
    .btn-pay {
        background: transparent;
        border: 1px solid #ff9f43;
        color: #ff9f43;
        font-size: 0.8rem;
        padding: 6px 18px;
        border-radius: 50px;
        text-decoration: none;
        transition: 0.3s;
    }

        .btn-pay:hover {
            background: #ff9f43;
            color: #000;
            box-shadow: 0 0 10px rgba(255, 159, 67, 0.4);
        }
</style>

<div class="container mt-5">
    <div class="purchase-history-section shadow-lg">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold">My Purchase History</h2>
            <p class="text-muted mb-0">Review and manage your art collection</p>
        </div>

        <div class="table-responsive">
            <table class="custom-art-table">
                <thead>
                    <tr>
                        <th>Artwork</th>
                        <th>Details</th>
                        <th>Price</th>
                        <th>Admin Status</th>
                        <th>Payment</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td>
                                @if (order.Artwork != null)
                                {
                                    <img src="~/images/@order.Artwork.ImageUrl" class="art-thumb" alt="art" />
                                }
                                else
                                {
                                    <div class="art-thumb bg-secondary d-flex align-items-center justify-content-center">N/A</div>
                                }
                            </td>

                            <td>
                                <div class="fw-bold text-white">@order.Artwork?.Title</div>
                                <small class="text-muted">ID: #@order.OrderId</small>
                            </td>

                            <td>
                                <span class="price-tag">Rs. @order.TotalAmount.ToString("N0")</span>
                            </td>

                            <td>
                                @if (order.AdminStatus == "Approved")
                                {
                                    <span class="badge-approved">APPROVED</span>
                                }
                                else
                                {
                                    <span class="badge-pending">@order.AdminStatus.ToUpper()</span>
                                }
                            </td>

                            <td>
                                <span class="@(order.PaymentStatus == "Paid" ? "text-success" : "text-light")">
                                    @order.PaymentStatus
                                </span>
                            </td>

                            <td class="text-end">
                                @if (order.AdminStatus == "Approved" && order.PaymentStatus == "Unpaid")
                                {
                                    <a asp-action="Checkout"
                                       asp-controller="User"
                                       asp-route-orderId="@order.OrderId"
                                       class="btn-pay">
                                        Pay Now
                                    </a>
                                }
                                else if (order.PaymentStatus == "Paid")
                                {
                                    <span class="text-success fw-bold small">COMPLETED</span>
                                }
                                else
                                {
                                    <span class="text-muted small">Awaiting...</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>