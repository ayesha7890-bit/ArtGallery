<div class="text-center mb-4">
    <div class="mb-3">
        <span class="step-pill">Login</span>
    </div>
    <h2 class="fw-bold mb-1">Welcome <span class="gold-text">Back</span></h2>
    <p class="text-white-50 small">Login to start your art journey today</p>
</div>
<form asp-action="Login" method="post">
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    @if (ViewBag.Error != null) 
   



    {
        <div class="alert alert-danger p-2 small border-0 mb-3" style="background-color: rgba(220, 53, 69, 0.1); color: #ff6b6b;">
            <i class="bi bi-exclamation-circle me-2"></i> @ViewBag.Error
        </div>
    }

    <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase opacity-50">Email Address</label>
        <input name="Email" type="email" class="form-control input-dark" placeholder="name@example.com" required />
    </div>

    <div class="mb-3">
        <label class="form-label small fw-bold text-uppercase opacity-50">Password</label>
        <input name="Password" type="password" class="form-control input-dark" placeholder="••••••••" required />
    </div>

    <div class="mt-4">
        <button type="submit" class="btn btn-action w-100">
            Login <i class="bi bi-box-arrow-in-right ms-2"></i>
        </button>
    </div>

    <div class="text-center mt-4">
        <p class="text-white-50 small">
            Don't have an account?
            <a asp-action="Register" class="gold-text text-decoration-none fw-bold ms-1">REGISTER HERE</a>
        </p>
    </div>
</form>