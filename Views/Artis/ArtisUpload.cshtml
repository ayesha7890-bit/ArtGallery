@model ArtGallery.ViewModels.ArtistView

@{
    ViewData["Title"] = "Upload Artwork";
    Layout = "_ArtisLayout";
}

<div class="page">
    <div class="page-header">
        <h1>Upload <span>Artwork</span></h1>
        <p>Share your masterpiece with the world</p>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}

<form asp-action="ArtisUpload" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <!-- Hidden status field -->
    <input type="hidden" asp-for="Status" value="Pending" />

    <!-- Upload Image -->
    <div class="card">
        <h3>Upload Image</h3>
        <label class="upload-box">
            <div class="upload-icon">⬆</div>
            <p><strong>Drag and drop your artwork here</strong></p>
            <p class="muted">or click to browse files (PNG, JPG, WEBP)</p>
            <input type="file" name="ImageFile" />
        </label>
    </div>

    <!-- Artwork Details -->
    <div class="card">
        <h3>Artwork Details</h3>
        <div class="form-group">
            <label>Title</label>
            <input asp-for="Title" placeholder="Enter artwork title" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Artist Name</label>
            <input asp-for="Artists" placeholder="Enter artist name" />
            <span asp-validation-for="Artists" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Category</label>
            <select asp-for="Category" required>
                <option value="">Select a category</option>
                @if (ViewBag.CategoryList != null)
                {
                    foreach (var cat in (IEnumerable<ArtGallery.Models.Category>)ViewBag.CategoryList)
                    {
                        <option value="@cat.Name">@cat.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="Category" class="text-danger"></span>
        </div>
    </div>

    <!-- Pricing -->
    <div class="card">
        <h3>Pricing</h3>
        <div class="form-group">
            <label>Type</label>
            <select asp-for="Type" required>
                <option value="">Select Type</option>
                <option value="Auction">Auction</option>
                <option value="Fixed">Fixed</option>
            </select>
            <span asp-validation-for="Type" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label>Price</label>
            <input asp-for="Price" type="number" step="0.01" required />
            <span asp-validation-for="Price" class="text-danger"></span>
        </div>
    </div>

    <!-- Auction Settings -->
    <div class="card" id="auctionSettings" style="display:none;">
        <h3>Auction Settings</h3>
        <div class="form-group">
            <label>Starting Bid</label>
            <input asp-for="StartingBid" type="number" step="0.01" placeholder="Enter starting bid" />
            <span asp-validation-for="StartingBid" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label>Auction Start Time</label>
            <input asp-for="AuctionStartTime" type="datetime-local" />
            <span asp-validation-for="AuctionStartTime" class="text-danger"></span>
        </div>
        <div class="form-group">
            <label>Auction End Time</label>
            <input asp-for="AuctionEndTime" type="datetime-local" />
            <span asp-validation-for="AuctionEndTime" class="text-danger"></span>
        </div>
    </div>

    <!-- Actions -->
    <div class="actions">
        <button type="submit" class="btn btn-primary">
            Upload Artwork
        </button>
    </div>
</form>

<!-- Scripts -->
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

<script>
    $(document).ready(function(){
        $('select[name="Type"]').change(function(){
            if($(this).val() == 'Auction'){
                $('#auctionSettings').show();
            } else {
                $('#auctionSettings').hide();
            }
        });
    });
</script>

<!-- Styles -->
<style>
    :root {
        --bg: #faf7f3;
        --card: #fff;
        --primary: #f97316;
        --text: #2b2b2b;
        --muted: #8b8b8b;
        --border: #e7e2dc;
        --soft: #fff3e9;
    }

    .page {
        max-width: 1100px;
        margin: 0 auto;
    }

    .page-header {
        text-align: center;
        margin-bottom: 32px;
    }

        .page-header h1 {
            font-size: 32px;
            font-weight: 700;
        }

        .page-header span {
            color: var(--primary);
        }

        .page-header p {
            color: var(--muted);
        }

    .card {
        background: var(--card);
        border-radius: 16px;
        padding: 24px;
        border: 1px solid var(--border);
        box-shadow: 0 8px 24px rgba(0,0,0,.03);
        margin-bottom: 24px;
    }

    .upload-box {
        border: 2px dashed var(--border);
        border-radius: 14px;
        padding: 40px 20px;
        text-align: center;
        cursor: pointer;
    }

        .upload-box:hover {
            border-color: var(--primary);
        }

    .upload-icon {
        width: 52px;
        height: 52px;
        margin: 0 auto 12px;
        border-radius: 50%;
        background: var(--soft);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--primary);
    }

    input, textarea, select {
        width: 100%;
        padding: 12px 14px;
        border-radius: 10px;
        border: 1px solid var(--border);
    }

    .actions {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    .btn {
        padding: 12px 20px;
        border-radius: 12px;
        font-weight: 600;
        border: none;
        cursor: pointer;
    }

    .btn-primary {
        background: var(--primary);
        color: #fff;
    }
</style>
