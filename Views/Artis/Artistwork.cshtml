@model IEnumerable<ArtGallery.ViewModels.ArtistView>

@{
    ViewData["Title"] = "My Portfolio";
    Layout = "_ArtisLayout";
}

<div class="portfolio-container">
    <header class="portfolio-header">
        <div class="header-titles">
            <h1>My Portfolio</h1>
            <p>Manage and track all your artworks</p>
        </div>
        <a href="/ArtisUpload" class="add-art-button"> <i class="fas fa-plus"></i> Add New Art</a>
    </header>

    <div class="filter-bar">
        <div class="search-input-wrapper">
            <i class="fas fa-search"></i>
            <input type="text" placeholder="Search artworks..." />
        </div>
    </div>

    <div class="art-grid-wrapper">
        <div class="art-grid">
            @foreach (var art in Model)
            {
                <div class="art-card">
                    <div class="art-image-container">
                        <img src="@art.ImageUrl" alt="@art.Title" class="art-main-img" />
                        @if (art.Type == "Auction")
                        {
                            <div class="type-badge">Auction</div>
                        }

                        <div class="card-options">
                            <button class="three-dots-btn" onclick="toggleDropdown(event, this)">
                                <i class="fas fa-ellipsis-v"></i>
                            </button>
                            <div class="options-menu">
                                
                                <a href="javascript:void(0)" onclick='openEditModal(@Json.Serialize(art))' class="menu-item edit-text">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="javascript:void(0)" onclick="deleteArt(@art.ArtworkId)" class="menu-item delete-text">
                                    <i class="fas fa-trash-alt"></i> Delete
                                </a>
                            
                               


                            </div>
                        </div>

                        <div class="status-badge @art.Status.ToLower()">@art.Status</div>
                    </div>

                  @*   <div class="art-info">
                        <h3 class="art-title">@art.Title</h3>
                        <p class="art-category">@art.Category</p> *@

                        @* <div class="art-footer">
                            <div class="art-date">
                                <i class="far fa-calendar-alt"></i> Dec 02, 2026
                            </div>
                            <div class="price-tag">₹@art.Price</div>
                        </div> *@
                        <div class="art-info">
                            <h3 class="art-title">@art.Title</h3>
                            <p class="art-category">@art.Category</p>

                            @if (art.Type == "Auction")
                            {
                                <div class="auction-info" style="background: #fff3e9; padding: 8px; border-radius: 8px; margin-bottom: 10px;">
                                    <div style="font-size: 12px; color: #f97316; font-weight: bold;">
                                        <i class="fas fa-gavel"></i> AUCTION
                                    </div>
                                    <div style="font-size: 13px; color: #475569;">
                                        Starting: <strong>₹@art.StartingBid</strong>
                                    </div>
                                </div>
                            }

                            <div class="art-footer">
                                <div class="art-date">
                                    <i class="far fa-calendar-alt"></i> Dec 02, 2026
                                </div>

                                @if (art.Type == "Auction")
                                {
                                    <div class="price-tag" style="color: #8b5cf6;">Bid Active</div>
                                }
                                else
                                {
                                    <div class="price-tag">₹@art.Price</div>
                                }
                            </div>
                        </div>
                    </div>
                
            }
        </div>
    </div>
</div>
