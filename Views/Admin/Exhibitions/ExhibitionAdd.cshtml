@model IEnumerable<ArtGallery.Models.Exhibition>
@{
    ViewData["Title"] = "Exhibitions";
    Layout = "_AdminLayout";
}
<!DOCTYPE html>

<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Art Gallery Admin Panel</title>

    <link rel="stylesheet" href="~/css/exhibition.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>

<body>
    <div class="main-content-wrapper">

        <div class="top-bar-controls">
            <div class="search-container">
                <i class="search-icon">🔍</i>
                <input type="text" class="search-input" placeholder="Search exhibitions...">
            </div>
            <button class="add-exhibition-btn" id="openModalBtn">+ Create Exhibition</button>
        </div>

        <div class="exhibitions-list-view">
            @foreach (var item in Model)
            {
                <div class="exhibition-card">

                    <div class="card-controls">
                        <div class="dots-icon">⋮</div>
                        <div class="dropdown-menu">
                            <a href="@Url.Action("ViewDetails", "Admin", new { id = item.ExhibitionId })" class="menu-item view-details">
                                <i class="fas fa-eye"></i> View Details
                            </a>
                        
                            <a href="javascript:void(0)"
                               class="menu-item edit"
                               onclick="openEditModal(@item.ExhibitionId)">
                                <i class="fas fa-edit"></i> Edit
                            </a>

                            <form asp-controller="Admin"
                                  asp-action="DeleteExhibition"
                                  asp-route-id="@item.ExhibitionId"
                                  method="post"
                                  onsubmit="return confirm('Are you sure you want to delete this exhibition?');">

                                <button type="submit" >
                                    Delete
                                </button>
                            </form>

                           

                        </div>
                    </div>
                    <div class="card-image-placeholder">
                        @if (!string.IsNullOrEmpty(item.BannerImage))
                        {
                            <img src="@item.BannerImage" alt="@item.Title">
                        }
                        else
                        {
                            <span>🎨</span>
                        }
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">@item.Title</h3>
                        <p class="card-description">@item.Description</p>
                        <div class="card-meta">
                            <span class="meta-item date">🗓 @item.StartDate.ToString("MMM dd, yyyy")</span>
                            <span class="meta-item works">🖼  works</span> 
                        </div>
                        <div class="card-status @(item.Status?.ToLower())">@item.Status?.ToUpper()</div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div id="createExhibitionModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" id="closeModal">&times;</span>
            <h2>Create New Exhibition</h2>
            <p>Set up a new exhibition to showcase artworks</p>
            <form id="exhibitionForm" asp-action="CreateExhibition" asp-controller="Admin" method="post" enctype="multipart/form-data">

                <div class="form-group">
                    <label for="Title">Exhibition Name *</label>
                    <input type="text" id="Title" name="Title" maxlength="200" placeholder="Enter exhibition name" required>
                </div>

                <div class="form-group">
                    <label for="Venue">Venue (Required)</label>
                    <input type="text" id="Venue" name="Venue" maxlength="500" placeholder="Enter venue location" required>
                </div>

                <div class="form-group date-container">
                    <div class="half-width">
                        <label for="StartDate">Start Date *</label>
                        <input type="date" id="StartDate" name="StartDate" required>
                    </div>
                    <div class="half-width">
                        <label for="EndDate">End Date *</label>
                        <input type="date" id="EndDate" name="EndDate" required>
                    </div>
                </div>

                <div class="form-group" style="clear: both;">
                    <label for="Description">Description</label>
                    <textarea id="Description" name="Description" maxlength="1000" placeholder="Describe your exhibition..."></textarea>
                </div>

                <div class="form-group">
                    <label for="BannerImage">Banner Image</label>
                    <input type="file" id="BannerImage" name="BannerImage">
                </div>

                <div class="modal-footer">
                    <button type="button" class="cancel-btn" id="cancelModalBtn">Cancel</button>
                    <button type="submit" class="submit-btn">Create Exhibition</button>
                </div>
            </form>
        </div>
    </div>
    <div id="editExhibitionModal" class="modal">
        <div class="modal-content">
            <span class="close-btn" id="closeEditModal">&times;</span>

            <h2>Edit Exhibition</h2>

            <form asp-action="EditExhibitionPost"
                  asp-controller="Admin"
                  method="post"
                  enctype="multipart/form-data">

                <input type="hidden" id="EditExhibitionId" name="ExhibitionId" />

                <div class="form-group">
                    <label>Exhibition Name *</label>
                    <input type="text" id="EditTitle" name="Title" required />
                </div>

                <div class="form-group">
                    <label>Venue *</label>
                    <input type="text" id="EditVenue" name="Venue" required />
                </div>

                <div class="date-container">
                    <div class="half-width">
                        <label>Start Date *</label>
                        <input type="date" id="EditStartDate" name="StartDate" required />
                    </div>
                    <div class="half-width">
                        <label>End Date *</label>
                        <input type="date" id="EditEndDate" name="EndDate" required />
                    </div>
                </div>

                <div class="form-group">
                    <label>Description</label>
                    <textarea id="EditDescription" name="Description"></textarea>
                </div>

                <div class="form-group">
                    <label>Change Banner Image</label>
                    <input type="file" name="BannerImage" />
                </div>

                <div class="modal-footer">
                    <button type="button" class="cancel-btn" id="cancelEditModal">Cancel</button>
                    <button type="submit" class="submit-btn">Update Exhibition</button>
                </div>
            </form>
        </div>
    </div>


</body>
</html>
<style>
    :root {
        --primary-color: #1C2833; /* Deep Slate/Dark Navy */
        --secondary-color: #7D3C98; /* Royal Purple (Highlight) */
        /* New Accent Gradient for Buttons (Purple to Gold/Orange) */
        --accent-color-start: #7D3C98;
        --accent-color-end: #C39C12; /* Vibrant Gold/Orange */
        /* Backgrounds */
        --background-light: #F4F6F6; /* Very Light Grey */
        --card-background: #F8F9F; /* <--- نئی تبدیلی */
        --text-color: #4A4A4A; /* Dark Grey Text */
        /* Shadows and Effects */
        --shadow-light: 0 8px 20px rgba(0,0,0,0.1); /* Deeper Shadow */
        /* Status Colors (Adjusted for contrast) */
        --success-color: #27AE60; /* Green */
        --warning-color: #F1C40F; /* Yellow */
        --archived-color: #A9A9A9; /* Medium Grey */
    }
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--background-light);
        color: var(--text-color);
        margin: 0;
        padding: 0;
    }

    /* Top Bar Controls */
    .top-bar-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 15px;
    }
    /* --- Search Container: Sleek & Animated --- */
    .search-container {
        display: flex;
        align-items: center;
        /* Using a very subtle background for depth */
        background-color: var(--background-light);
        /* Soft border - initially subtle */
        border: 2px solid #DCDDE1;
        /* Rounded edges for a modern look */
        border-radius: 50px;
        padding: 10px 20px; /* Increased padding */
        max-width: 400px; /* Slightly wider */
        flex-grow: 1;
        /* Smooth transition for focus effect */
        transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
        /* Subtle initial shadow */
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

        /* Amazing Focus Effect! */
        .search-container:focus-within {
            /* Border color changes to the highlight color (Purple) */
            border-color: var(--secondary-color);
            /* Prominent shadow effect on focus */
            box-shadow: 0 0 15px rgba(125, 60, 152, 0.3); /* Purple Glow */

            background-color: var(--card-background); /* White background when active */
        }

    /* --- Search Icon --- */
    .search-icon {
        margin-right: 12px;
        /* Icon color is now the secondary (Royal Purple) */
        color: var(--secondary-color);
        font-size: 18px; /* Slightly larger icon */
        transition: color 0.4s ease;
    }

    /* --- Search Input --- */
    .search-input {
        border: none;
        outline: none;
        padding: 0; /* Padding moved to container */
        font-size: 17px;
        width: 100%;
        /* Transparent background ensures the container's background shows */
        background: transparent;
        color:white;
    }
        
    

    .add-exhibition-btn {
        background: linear-gradient(45deg, var(--accent-color-start), var(--accent-color-end));
        color: white;
        border: none;
        padding: 12px 25px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(243,156,18,0.5);
        min-width: 180px;
        text-align: center;
    }

        .add-exhibition-btn:hover {
            background: linear-gradient(45deg, var(--accent-color-end), var(--accent-color-start));
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(230,126,34,0.7);
        }

    /* Exhibition Cards Grid */
    .exhibitions-list-view {
        display: grid !important;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)) !important; /* Adjusted for responsiveness */
        gap: 25px !important;
        width: 100%;
        box-sizing: border-box;
        margin-top: 30px;
    }

    /* Card Styling */
    /* Card Styling with Premium Gradient Effect */
    .exhibition-card {
        background-color: var(--card-background);
        color: var(--text-color);
        border-radius: 15px; /* Softer radius */
        overflow: hidden;
        /* Updated Shadow */
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        /* Animation Control */
        transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.4s ease;
        position: relative;
        z-index: 1; /* Ensure card is above its gradient border */
        /* === NEW: Gradient Border Preparation === */
        padding: 2px; /* Add padding to contain the gradient border visually */
        border: none;
    }

        /* Gradient Border Effect using ::before */
        .exhibition-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border-radius: 15px;
            z-index: -1; /* Place behind the card content */
            /* The Actual Gradient Border */
            background: linear-gradient(135deg, var(--accent-color-start) 0%, var(--accent-color-end) 100%);
            opacity: 0; /* Initially hidden */
            transition: opacity 0.4s ease, transform 0.4s ease;
            transform: scale(1.0);
        }

        /* Apply Gradient Border and Lift on Hover */
        .exhibition-card:hover {
            transform: translateY(-8px); /* Stronger lift-up */
            /* Deep shadow matching the new theme */
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.25);
        }

            /* Show the Gradient Border on Hover */
            .exhibition-card:hover::before {
                opacity: 1; /* Make gradient visible */
                transform: scale(1.01); /* Slightly scale to act as a border */
            }

        /* Inner Content Fix for Padding */
        .exhibition-card > div {
            /* Ensure all inner content sits nicely inside the padding and has a white background */
            background-color: var(--card-background);
            border-radius: 13px; /* Slightly smaller than parent border-radius */
        }

    /* Fix image placeholder to fill top of the card */
    .card-image-placeholder {
        border-top-left-radius: 13px;
        border-top-right-radius: 13px;
    }

    /* === NEW: Card Controls/3-Dot Menu Styling === */
    .card-controls {
        position: absolute;
        top: 15px;
        right: 15px;
        z-index: 10; /* Ensure it's above other elements */
    }

    .dots-icon {
        font-size: 24px;
        font-weight: bold;
        color: #fff;
        /* background-color: rgba(0, 0, 0, 0.5); */
        padding: 0 8px;
        border-radius: 50%;
        cursor: pointer;
        line-height: 24px;
        height: 30px;
        width: 30px;
        text-align: center;
        box-sizing: border-box;
        transition: background-color 0.2s;
    }

        .dots-icon:hover {
            background-color: rgba(0, 0, 0, 0.7);
        }

    /* Dropdown Menu Styling (Initially Hidden) */
    .dropdown-menu {
        display: none; /* Initially hidden */
        position: absolute;
        top: 35px; /* Position below the dots icon */
        right: 0;
        background-color: var(--background-light);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
        border-radius: 8px;
        overflow: hidden;
        min-width: 160px;
        z-index: 20;
        padding: 5px 0;
        border: 1px solid #eee;
    }

    /* Show dropdown when a class is active on card-controls */
    .card-controls.active .dropdown-menu {
        display: block;
    }

    .menu-item {
        display: flex;
        align-items: center;
        padding: 10px 15px;
        text-decoration: none;
        color: var(--text-color);
        font-size: 0.9em;
        transition: background-color 0.2s, color 0.2s;
        white-space: nowrap;
    }

        .menu-item i {
            margin-right: 10px;
            font-size: 14px;
        }

        .menu-item:hover {
            background-color: var(--background-light);
            color: var(--secondary-color);
        }

        .menu-item.delete {
            color: #e74c3c;
        }

            .menu-item.delete:hover {
                background-color: #ffe8e6;
                color: #c0392b;
            }
    /* === END: Card Controls/3-Dot Menu Styling === */


    .card-image-placeholder {
        width: 100%;
        height: 200px;
        background-color: var(--background-light);
        display: flex;
        justify-content: center;
        align-items: center;
        font-size: 48px;
        overflow: hidden;
    }

        .card-image-placeholder img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .card-content {
        padding: 20px;
        position: relative;
    }

    .card-title {
        margin: 0 0 10px 0;
        font-size: 1.3em;
        font-weight: 600;
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .card-description {
        font-size: 0.9em;
        color: #666;
        margin-bottom: 15px;
        height: 3em;
        line-height: 1.5em;
        overflow: hidden;
    }

    .card-meta {
        display: flex;
        gap: 15px;
        font-size: 0.85em;
        color: #999;
        margin-bottom: 20px;
    }

    .card-status {
        /* Adjusted position so it doesn't overlap too much with the menu icon,
               but based on your original screenshot, it's inside card-content. */
        position: static;
        display: inline-block;
        padding: 5px 10px;
        border-radius: 5px;
        font-weight: bold;
        font-size: 0.75em;
    }
        /* ... (Rest of Modal and other CSS remain the same) ... */

        .card-status.draft {
            background-color: #f1c40f;
            color: #000;
        }

        .card-status.upcoming,
        .card-status.active {
            background-color: #2ecc71;
            color: #fff;
        }

        .card-status.archived,
        .card-status.ended {
            background-color: #95a5a6;
            color: #fff;
        }

    /* Modal Styling */
    .modal {
        display: none;
        position: fixed;
        z-index: 1000;
        left: 0;
        top: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0,0,0,0.4);
        overflow: auto;
    }

    .modal-content {
        background-color: #fff;
        color: #333;
        margin: 5% auto;
        padding: 30px 40px;
        border-radius: 15px;
        width: 90%;
        max-width: 600px;
        position: relative;
        box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        animation: fadeIn 0.3s ease;
        font-family: 'Inter', sans-serif;
    }

        .modal-content h2 {
            margin-top: 0;
            font-size: 1.8em;
            color: var(--primary-color);
            text-align: center;
            margin-bottom: 20px;
        }

        .modal-content p {
            text-align: center;
            color: #666;
            font-size: 0.95em;
            margin-bottom: 25px;
        }

    /* Form Groups */
    .form-group {
        margin-bottom: 20px;
        display: flex;
        flex-direction: column;
    }

        .form-group label {
            font-weight: 600;
            margin-bottom: 8px;
            color: var(--primary-color);
        }

        .form-group input[type="text"],
        .form-group input[type="date"],
        .form-group input[type="file"],
        .form-group textarea {
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid #ccc;
            font-size: 1em;
            outline: none;
            transition: border 0.3s ease, box-shadow 0.3s ease;
        }

            .form-group input:focus,
            .form-group textarea:focus {
                border-color: var(--secondary-color);
                box-shadow: 0 0 5px rgba(52,152,219,0.3);
            }

    textarea {
        resize: vertical;
        min-height: 80px;
    }

    /* Half-width fields */
    .date-container {
        display: flex;
        gap: 15px;
    }

    .half-width {
        flex: 1;
    }

    /* Buttons */
    .modal-footer {
        padding-top: 10px;
        border-top: 1px solid #eee;
        display: flex;
        justify-content: flex-end;
        gap: 15px;
    }

    .cancel-btn {
        background: linear-gradient(45deg, #bdc3c7, #95a5a6); /* subtle gradient */
        color: var(--primary-color);
        font-weight: 600;
        padding: 10px 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(0,0,0,0.2);
    }

        .cancel-btn:hover {
            background: linear-gradient(45deg, #aeb4b8, #8c8c8c);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0,0,0,0.3);
        }

    .submit-btn {
        background: linear-gradient(45deg, var(--accent-color-start), var(--accent-color-end));
        color: white;
        border: none;
        padding: 12px 25px;
        font-size: 16px;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 10px rgba(243,156,18,0.5);
    }

        .submit-btn:hover {
            background-color: #2980b9;
            transform: translateY(-2px);
        }

    /* Close Button */
    .close-btn {
        position: absolute;
        top: 15px;
        right: 20px;
        font-size: 28px;
        font-weight: bold;
        color: #aaa;
        cursor: pointer;
        transition: color 0.3s ease;
    }

        .close-btn:hover {
            color: var(--secondary-color);
        }

    /* Ensure parent content allows full width */
    .content {
        margin-left: 300px;
        padding: 30px;
        width: calc(100% - 300px);
        box-sizing: border-box;
    }
</style>

<script>
    // Modal Script (Existing)
    var modal = document.getElementById("createExhibitionModal");
    var openBtn = document.getElementById("openModalBtn");
    var closeSpan = document.getElementById("closeModal");
    var cancelBtn = document.getElementById("cancelModalBtn");

    openBtn.onclick = function(){ modal.style.display="block"; }
    closeSpan.onclick = function(){ modal.style.display="none"; }
    cancelBtn.onclick = function(){ modal.style.display="none"; }
    window.onclick = function(event){ if(event.target==modal){ modal.style.display="none"; } }

    // NEW: Dropdown Toggle Script
    document.addEventListener('DOMContentLoaded', (event) => {
        // Select all dot icons
        const dotIcons = document.querySelectorAll('.dots-icon');

        dotIcons.forEach(icon => {
            icon.addEventListener('click', function(e) {
                e.stopPropagation(); // Prevent the click from immediately closing the menu

                // Get the parent card-controls div
                const controls = this.closest('.card-controls');

                // Close all other open dropdowns
                document.querySelectorAll('.card-controls.active').forEach(openControls => {
                    if (openControls !== controls) {
                        openControls.classList.remove('active');
                    }
                });

                // Toggle the 'active' class on the current card-controls
                controls.classList.toggle('active');
            });
        });

        // Close the dropdown when clicking anywhere else on the document
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.card-controls')) {
                document.querySelectorAll('.card-controls.active').forEach(openControls => {
                    openControls.classList.remove('active');
                });
            }
        });
    });
  
    function openEditModal(id) {
        fetch(`/Dashboard/GetExhibition/${id}`)
            .then(res => res.json())
            .then(data => {
                document.getElementById("EditExhibitionId").value = data.exhibitionId;
                document.getElementById("EditTitle").value = data.title;
                document.getElementById("EditVenue").value = data.venue;
                document.getElementById("EditDescription").value = data.description || "";
                document.getElementById("EditStartDate").value = data.startDate;
                document.getElementById("EditEndDate").value = data.endDate;

                document.getElementById("editExhibitionModal").style.display = "block";
            });
    }

    document.getElementById("closeEditModal").onclick =
    document.getElementById("cancelEditModal").onclick = function () {
        document.getElementById("editExhibitionModal").style.display = "none";
    };


</script>