@model IEnumerable<ArtGallery.Models.Artist>

@{
    ViewData["Title"] = "Artworks";
    Layout = "_AdminLayout";
}

<style>
    :root {
        --primary-orange: #FF9100;
        --dark-bg: #1e1e1e;
        --card-bg: #252525;
        --border-color: #333333;
        --text-muted: #9ca3af;
        --transition: all 0.3s ease;
    }

    body {
        background-color: var(--dark-bg);
        color: white;
        font-family: 'Segoe UI', Roboto, sans-serif;
    }

    /* Table Container Styling */
    .custom-card {
        background: var(--card-bg);
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.4);
        margin-top: 20px;
    }

    .table-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 25px;
    }

    .title-area h2 {
        font-size: 28px;
        font-weight: 600;
        margin: 0;
    }

    /* Modern Table Design */
    .art-table {
        width: 100%;
        border-collapse: collapse;
    }

        .art-table thead th {
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 13px;
            font-weight: 500;
            padding: 15px;
            border-bottom: 1px solid var(--border-color);
            text-align: left;
        }

        .art-table tbody tr {
            border-bottom: 1px solid var(--border-color);
            transition: var(--transition);
        }

            /* Table Row Hover Effect */
            .art-table tbody tr:hover {
                background: rgba(255, 145, 0, 0.05); /* Light orange tint on hover */
                transform: scale(1.002);
            }

        .art-table td {
            padding: 15px;
            vertical-align: middle;
            font-size: 14px;
        }

    /* Image Styling */
    .artwork-img {
        width: 55px;
        height: 55px;
        object-fit: cover;
        border-radius: 6px;
        border: 1px solid #444;
    }

    /* Orange Gradient Buttons (Like Add Category) */
    .btn-orange {
        background: linear-gradient(90deg, #FF9100 0%, #FF6D00 100%);
        color: white !important;
        border: none;
        padding: 8px 16px;
        border-radius: 5px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 5px;
        transition: var(--transition);
        cursor: pointer;
    }

        .btn-orange:hover {
            filter: brightness(1.2);
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 145, 0, 0.3);
        }

    /* Delete Button Styling */
    .btn-outline-danger {
        background: transparent;
        color: #ef4444 !important;
        border: 1px solid #ef4444;
        padding: 7px 15px;
        border-radius: 5px;
        font-size: 12px;
        transition: var(--transition);
    }

        .btn-outline-danger:hover {
            background: #ef4444;
            color: white !important;
        }

    /* Badge Styling */
    .status-badge {
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: bold;
    }

    .status-pending {
        background: #333;
        color: #FF9100;
        border: 1px solid #FF9100;
    }

    .status-approved {
        background: rgba(34, 197, 94, 0.2);
        color: #22c55e;
    }
</style>

<div class="table-header-flex">
    <div class="title-area">
        <h2>Artworks</h2>
        <p style="color: var(--text-muted); font-size: 14px;">Review and manage art submissions</p>
    </div>
</div>

<div class="custom-card">
    <table class="art-table">
        <thead>
            <tr>
                <th>Artwork</th>
                <th>Details</th>
                <th>Category</th>
                <th>Price</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default.jpg" : item.ImageUrl)" class="artwork-img" />
                    </td>
                    <td>
                        <div style="font-weight: 600;">@item.Title</div>
                        <div style="color: var(--text-muted); font-size: 12px;">By @item.Artists</div>
                    </td>
                    <td>@item.Category</td>
                    <td style="color: var(--primary-orange); font-weight: bold;">@item.Price.ToString("C")</td>
                    <td>
                        @if (item.Status == "Pending")
                        {
                            <span class="status-badge status-pending">PENDING</span>
                        }
                        else
                        {
                            <span class="status-badge status-approved">@item.Status.ToUpper()</span>
                        }
                    </td>
                    <td class="text-end">
                        <div style="display: flex; gap: 8px; justify-content: flex-end;">
                            @if (item.Status == "Pending")
                            {
                                <form asp-action="ApproveArtwork" asp-route-id="@item.ArtworkId" method="post">
                                    <button type="submit" class="btn-orange">Approve</button>
                                </form>
                                <form asp-action="RejectArtwork" asp-route-id="@item.ArtworkId" method="post">
                                    <button type="submit" class="btn-orange" style="background: #444;">Reject</button>
                                </form>
                            }

                            <form asp-action="DeleteArtwork" asp-route-id="@item.ArtworkId" method="post"
                                  onsubmit="return confirm('Delete this artwork?');">
                                <button type="submit" class="btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>