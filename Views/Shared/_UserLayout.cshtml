@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - ArtGallery</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/User.css" />

    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- ================= NAVBAR ================= -->
    <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
        <div class="container">
            <a class="navbar-brand" asp-controller="User" asp-action="User">ArtGallerY</a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav mx-auto">
                    <li class="nav-item"><a class="nav-link text-white" asp-controller="User" asp-action="User">Home</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#Exhibitions">Exhibition</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#collection">Gallery</a></li>
                    <li class="nav-item"><a class="nav-link text-white" href="#Auctions">Auctions</a></li>
                </ul>

                @if (HttpContextAccessor.HttpContext.Session.GetString("UserName") != null)
                {
                    <span class="text-white me-3">
                        Hi, <b>@HttpContextAccessor.HttpContext.Session.GetString("UserName")</b>
                    </span>

                    <a asp-controller="User" asp-action="Logout" class="btn-art-solid">
                        <i class="fas fa-sign-out-alt"></i> Logout
                    </a>
                }
                else
                {
                    <a asp-controller="User" asp-action="Login" class="btn-art-outline">Sign In</a>
                    <a asp-controller="User" asp-action="Register" class="btn-art-solid">Sign Up</a>
                }
            </div>
        </div>
    </nav>
    <!-- ================= NAVBAR END ================= -->
    <!-- ================= PAGE BODY ================= -->
    <main>
        @RenderBody()
    </main>
    <!-- ================= BODY END ================= -->
    <!-- ================= FOOTER ================= -->
    <footer class="footer-custom mt-5">
        <hr class="footer-divider" />

        <div class="container text-center pb-3">
            <p class="mb-1">&copy; 2024 Artisan Gallery. All rights reserved.</p>

            <div class="bottom-links">
                <a href="#">Privacy Policy</a>
                <a href="#">Terms of Service</a>
                <a href="#">Cookie Policy</a>
            </div>
        </div>
    </footer>
    <!-- ================= FOOTER END ================= -->
    <!-- JS -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

    <script>
        AOS.init({ duration: 1200, once: true });

        $(window).scroll(function () {
            if ($(this).scrollTop() > 50) {
                $('.navbar-custom').addClass('navbar-scrolled');
            } else {
                $('.navbar-custom').removeClass('navbar-scrolled');
            }
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
