<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Art Gallery - Join Us</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #000; /* Deep black [cite: 22] */
            color: #fff;
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
        }

        /* Background overlay with lower opacity for a "distant" feel */
        .auth-bg {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            background: linear-gradient(rgba(0,0,0,0.85), rgba(0,0,0,0.85)), url('https://art-profile-builder.lovable.app/assets/gallery-hero-C__0mGNL.jpg') center/cover;
            z-index: -1;
        }

        .wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        /* Refined Card size - Less zoomed in */
        .glass-card {
            background: rgba(20, 20, 20, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 480px; /* Thora dur aur compact dikhne ke liye */
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }

        .gold-text {
            background: linear-gradient(to right, #ffaa00, #ff6600);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .input-dark {
            background: rgba(255, 255, 255, 0.04) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #fff !important;
            border-radius: 12px;
            padding: 12px 15px;
            font-size: 0.9rem;
        }

            .input-dark:focus {
                border-color: #ffaa00 !important;
                box-shadow: 0 0 15px rgba(255, 170, 0, 0.2);
            }

        /* Premium Orange Button from your main page theme */
        .btn-action {
            background: linear-gradient(45deg, #ff8800, #ff4400);
            border: none;
            color: #000;
            font-weight: 700;
            padding: 14px;
            border-radius: 12px;
            transition: 0.3s;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

            .btn-action:hover {
                transform: scale(1.02);
                box-shadow: 0 5px 20px rgba(255, 100, 0, 0.4);
            }

        /* Stepper refinement */
        .step-pill {
            background: rgba(255, 170, 0, 0.1);
            color: #ffaa00;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            border: 1px solid rgba(255, 170, 0, 0.3);
        }
    </style>
</head>
<body>
    <div class="auth-bg"></div>
    <div class="wrapper">
        <div class="glass-card">
            @RenderBody()
        </div>
    </div>
</body>
</html>